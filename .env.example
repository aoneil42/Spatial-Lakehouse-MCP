# ── LakeKeeper ──
SLM_CATALOG_URI=http://lakekeeper:8181
SLM_CATALOG_WAREHOUSE=warehouse
SLM_CATALOG_ALIAS=lakehouse

# OAuth2 auth (leave empty for no-auth dev mode)
SLM_CATALOG_CLIENT_ID=
SLM_CATALOG_CLIENT_SECRET=
SLM_CATALOG_OAUTH2_SCOPE=
SLM_CATALOG_OAUTH2_SERVER_URI=

# Or use a bearer token instead:
# SLM_CATALOG_TOKEN=your_token_here

# ── Garage S3 ──
GARAGE_KEY_ID=your_garage_key
GARAGE_SECRET_KEY=your_garage_secret
SLM_S3_ENDPOINT=garage:3900
SLM_S3_REGION=garage
SLM_S3_USE_SSL=false
SLM_S3_URL_STYLE=path

# ── validate_stack.py reads these (falls back to hardcoded dev defaults) ──
# GARAGE_KEY_ID=GK8e7e0e5439eda8588e0a2693
# GARAGE_SECRET_KEY=3dfca5c6f09403e7b954f94a91f59a61c1c3c9230ac5d50e8bba58c81c3a1533

# ── Query Limits ──
SLM_MAX_RESULT_ROWS=5000
SLM_DEFAULT_RESULT_ROWS=100
SLM_QUERY_TIMEOUT_SECONDS=30

# ── Server ──
SLM_SERVER_PORT=8082
